{
  "models": {
    "memory-small": {
      "provider": "openai-compatible",
      "baseURL": "http://127.0.0.1:11434/v1",
      "model": "REPLACE_WITH_SMALL_LOCAL_MODEL",
      "useFor": [
        "memory_extraction",
        "session_summary"
      ]
    },
    "review-open": {
      "provider": "openai-compatible",
      "baseURL": "http://127.0.0.1:8000/v1",
      "model": "REPLACE_WITH_REVIEW_MODEL",
      "useFor": [
        "read_only_code_review"
      ]
    },
    "patch-author": {
      "provider": "openai-codex",
      "model": "REPLACE_WITH_RELIABLE_PATCH_MODEL",
      "useFor": [
        "patch_authoring"
      ]
    }
  },
  "routing": {
    "mode": "manual",
    "notes": "Do not add an automatic router until model behavior is measured."
  }
}

